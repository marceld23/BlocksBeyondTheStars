TestResults/

# Savegames / runtime data
saves/
*.db
*.db-shm
*.db-wal
logs/
backups/

# /bump bug reports written when the server runs from inside the repo (dev only).
/bugreports/

# Local planning / requirement specs (kept out of the repo by request)
plans/

# Generated Unity client content (reproduce via scripts/sync-client-libs.ps1).
# Ignore synced plugin payloads, but keep hand-written WebGL browser plugins versioned.
client/Assets/Plugins/*
!client/Assets/Plugins/BbsWebSocket.jslib
!client/Assets/Plugins/BbsWebSocket.jslib.meta
client/Assets/Plugins.meta
client/Assets/StreamingAssets/
client/Assets/StreamingAssets.meta

# Build-script scratch logs + markers (scripts/*.log, scripts/_lastbuild.txt, ...). Broad *.log
# match: build scripts emit many ad-hoc logs here (build-*.log, _lookbuild_*.log, ...); none are tracked.
scripts/*.log
scripts/_*.txt

# Local build/capture run logs at the repo root (build-run*.log, capture-run*.log, ...)
/*.log

# Unity client build/capture logs (build-*.log, capture-run*.log, ...) — generated, never tracked.
client/*.log

# Local-only marketing scratch (website copy drafts etc.); screenshots live under docs/screenshots/
/marketing/

# Python bytecode (tools/)
__pycache__/
*.pyc

# OS
Thumbs.db
.DS_Store

# Stray / unrelated folders that exist in this workspace
